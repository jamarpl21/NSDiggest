# --- Gmail IMAP/SMTP (newsletter source mailbox) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Digest recipient ---
DIGEST_TO=
DIGEST_FROM_NAME=Newsletter Digest

# --- Anthropic API ---
# Required for PROCESSING_MODE=llm-only or hybrid; optional for no-llm
ANTHROPIC_API_KEY=sk-ant-...

# Processing mode: no-llm | llm-only | hybrid
PROCESSING_MODE=llm-only

# Stage 1: per-newsletter topic extraction (parallel LLM calls)
# Recommended: claude-sonnet-4-6 (fast/cost-efficient); use opus for higher quality if needed
ANTHROPIC_MODEL_STAGE1=claude-sonnet-4-6

# Stage 2: cross-newsletter deduplication (single lightweight call on compact JSON)
ANTHROPIC_MODEL_STAGE2=claude-sonnet-4-6

# Max concurrent Stage 1 LLM calls (increase if your rate limits allow it)
STAGE1_MAX_WORKERS=5

# Sonnet 4.6 API pricing defaults (USD per 1M tokens)
STAGE1_INPUT_USD_PER_MTOK=3.0
STAGE1_OUTPUT_USD_PER_MTOK=15.0
STAGE1_CACHE_WRITE_USD_PER_MTOK=3.75
STAGE1_CACHE_READ_USD_PER_MTOK=0.30
STAGE2_INPUT_USD_PER_MTOK=3.0
STAGE2_OUTPUT_USD_PER_MTOK=15.0
STAGE2_CACHE_WRITE_USD_PER_MTOK=3.75
STAGE2_CACHE_READ_USD_PER_MTOK=0.30

# --- Runtime ---
# How many days back to include (in addition to all UNSEEN emails)
LOOKBACK_DAYS=1
# Artifacts directory (raw/digest JSON and logs); defaults to ./data
DATA_DIR=/var/lib/nsdiggest
# Log level: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
# Dry run: do not send and do not mark as SEEN
DRY_RUN=0
